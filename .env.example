# Copy this file to `.env` and adjust for your environment.
# `.env` is gitignored; never commit real secrets.

# ── PostgreSQL connection ────────────────────────────────────────────────────
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=coivitas_dev
PGUSER=coivitas
PGPASSWORD=coivitas
DATABASE_URL=postgresql://coivitas:coivitas@127.0.0.1:5432/coivitas_dev

# ── Ledger & governance (required by CLI `ledger verify` / golden-path / e2e) ──
# Ledger signing private key (32-byte hex = 64 chars). Independent of the agent
# private key; injected by operators. Use a real key in production.
# LEDGER_PRIVATE_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Governor (did:system:session-governor) public key (32-byte hex = 64 chars).
# Since v0.3.0, SESSION_SUPERSEDED is a normal behavior record; without this key
# the CLI `ledger verify` cannot verify governor records and aborts rather than
# silently misjudging.
# GOVERNOR_PUBLIC_KEY=<governor-ed25519-public-key-hex>

# Identity registry URL (the DID-resolution backend for CLI commands + golden-path).
# If unset, golden-path starts a local HTTP service automatically. CLI commands
# require this to be set explicitly.
# IDENTITY_REGISTRY_URL=http://127.0.0.1:3001

# Optional: set to 1 to enable the federation/handshake E2E tests that depend on
# TCP ports (adds ~20s; requires Docker and free ports).
# ENABLE_SOCKET_TESTS=1
