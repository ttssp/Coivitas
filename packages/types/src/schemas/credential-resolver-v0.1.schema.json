{
 "$id": "https://coivitas.ai/schemas/credential-resolver-v0.1.json",
 "$schema": "http://json-schema.org/draft-07/schema#",
 "title": "CredentialResolver",
 "description": "CR v0.1 JSON Schema. Multiple schema $defs entry points: OidcRawClaims / SamlRawClaims / NormalizedOidcClaims / NormalizedSamlClaims / FederationIdentityLink / ResolvedCredentialIntegrityProof / ResolvedCredential. A fallback of additionalProperties:true is strictly forbidden, as it would break type isolation.",
 "type": "object",
 "$defs": {
  "OidcRawClaims": {
   "$id": "#/$defs/OidcRawClaims",
   "title": "OidcRawClaims",
   "description": "Raw claims returned by the OIDC IdP; field set sourced from OIDC Core 1.0 §5.1 + §2; a fallback of additionalProperties:true is strictly forbidden",
   "type": "object",
   "required": [
    "iss",
    "sub",
    "aud",
    "exp",
    "iat"
   ],
   "additionalProperties": false,
   "properties": {
    "iss": {
     "type": "string",
     "format": "uri",
     "minLength": 1
    },
    "sub": {
     "type": "string",
     "minLength": 1
    },
    "aud": {
     "oneOf": [
      {
       "type": "string",
       "minLength": 1
      },
      {
       "type": "array",
       "items": {
        "type": "string",
        "minLength": 1
       },
       "minItems": 1
      }
     ]
    },
    "exp": {
     "type": "integer",
     "minimum": 0
    },
    "iat": {
     "type": "integer",
     "minimum": 0
    },
    "nbf": {
     "type": "integer",
     "minimum": 0
    },
    "nonce": {
     "type": "string",
     "minLength": 1
    },
    "email": {
     "type": "string",
     "format": "email"
    },
    "email_verified": {
     "type": "boolean"
    },
    "preferred_username": {
     "type": "string"
    },
    "name": {
     "type": "string"
    }
   }
  },
  "SamlRawClaims": {
   "$id": "#/$defs/SamlRawClaims",
   "title": "SamlRawClaims",
   "description": "Raw attributes returned by the SAML IdP; field set sourced from SAML 2.0 Core §2.5 + §2.7; a fallback of additionalProperties:true is strictly forbidden",
   "type": "object",
   "required": [
    "nameId",
    "nameIdFormat",
    "issuer",
    "audience",
    "attributes"
   ],
   "additionalProperties": false,
   "properties": {
    "nameId": {
     "type": "string",
     "minLength": 1
    },
    "nameIdFormat": {
     "type": "string",
     "format": "uri"
    },
    "issuer": {
     "type": "string",
     "format": "uri"
    },
    "audience": {
     "type": "string",
     "minLength": 1
    },
    "notBefore": {
     "type": "string",
     "format": "date-time"
    },
    "notOnOrAfter": {
     "type": "string",
     "format": "date-time"
    },
    "sessionIndex": {
     "type": "string"
    },
    "attributes": {
     "type": "object",
     "additionalProperties": {
      "type": "array",
      "items": {
       "type": "string"
      }
     }
    }
   }
  },
  "NormalizedOidcClaims": {
   "$id": "#/$defs/NormalizedOidcClaims",
   "title": "NormalizedOidcClaims",
   "description": "Normalized claims after extraction by the OIDC port implementation layer",
   "type": "object",
   "required": [
    "source",
    "issuer",
    "subject",
    "audience",
    "expiresAt",
    "issuedAt"
   ],
   "additionalProperties": false,
   "properties": {
    "source": {
     "type": "string",
     "enum": [
      "oidc"
     ]
    },
    "issuer": {
     "type": "string",
     "minLength": 1
    },
    "subject": {
     "type": "string",
     "minLength": 1
    },
    "audience": {
     "type": "array",
     "items": {
      "type": "string",
      "minLength": 1
     },
     "minItems": 1
    },
    "expiresAt": {},
    "issuedAt": {},
    "nonce": {
     "type": "string",
     "minLength": 1
    },
    "email": {
     "type": "string"
    },
    "emailVerified": {
     "type": "boolean"
    },
    "preferredUsername": {
     "type": "string"
    },
    "displayName": {
     "type": "string"
    }
   }
  },
  "NormalizedSamlClaims": {
   "$id": "#/$defs/NormalizedSamlClaims",
   "title": "NormalizedSamlClaims",
   "description": "Normalized claims after extraction by the SAML port implementation layer",
   "type": "object",
   "required": [
    "source",
    "issuer",
    "subject",
    "subjectFormat",
    "audience",
    "attributes"
   ],
   "additionalProperties": false,
   "properties": {
    "source": {
     "type": "string",
     "enum": [
      "saml"
     ]
    },
    "issuer": {
     "type": "string",
     "minLength": 1
    },
    "subject": {
     "type": "string",
     "minLength": 1
    },
    "subjectFormat": {
     "type": "string",
     "minLength": 1
    },
    "audience": {
     "type": "array",
     "items": {
      "type": "string",
      "minLength": 1
     },
     "minItems": 1
    },
    "notBefore": {},
    "notOnOrAfter": {},
    "sessionIndex": {
     "type": "string"
    },
    "attributes": {}
   }
  },
  "FederationIdentityLink": {
   "$id": "#/$defs/FederationIdentityLink",
   "title": "FederationIdentityLink",
   "description": "Federation-user-to-app-user mapping record; persisted to the federation_identity_links table: user_id must have an FK REFERENCES managed_service.users(id) ON DELETE RESTRICT",
   "type": "object",
   "required": [
    "id",
    "tenantId",
    "source",
    "issuer",
    "federatedSubject",
    "userId",
    "signature",
    "createdAt",
    "revoked"
   ],
   "additionalProperties": false,
   "properties": {
    "id": {
     "type": "string",
     "format": "uuid",
     "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "tenantId": {
     "type": "string",
     "format": "uuid",
     "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "source": {
     "type": "string",
     "enum": [
      "oidc",
      "saml",
      "did"
     ]
    },
    "issuer": {
     "type": "string",
     "format": "uri"
    },
    "federatedSubject": {
     "type": "string",
     "minLength": 1
    },
    "userId": {
     "type": "string",
     "format": "uuid",
     "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "signature": {
     "type": "string",
     "pattern": "^[0-9a-f]{128}$"
    },
    "createdAt": {
     "type": "string",
     "format": "date-time"
    },
    "lastVerifiedAt": {
     "type": "string",
     "format": "date-time"
    },
    "revoked": {
     "type": "boolean"
    },
    "expectedAudience": {
     "type": "string",
     "minLength": 1
    }
   }
  },
  "ResolvedCredentialIntegrityProof": {
   "$id": "#/$defs/ResolvedCredentialIntegrityProof",
   "title": "ResolvedCredentialIntegrityProof",
   "description": "verify-time signed payload",
   "type": "object",
   "required": [
    "token",
    "disclosedClaims",
    "challenge",
    "audience",
    "notAfter",
    "cspVersion",
    "proofSignature",
    "resolverDid"
   ],
   "additionalProperties": false,
   "properties": {
    "token": {
     "type": "string",
     "minLength": 1
    },
    "disclosedClaims": {
     "type": "array",
     "items": {
      "type": "string"
     }
    },
    "challenge": {
     "type": "string",
     "minLength": 1
    },
    "audience": {
     "type": "string",
     "pattern": "^did:"
    },
    "notAfter": {
     "type": "string",
     "format": "date-time"
    },
    "cspVersion": {
     "type": "string",
     "enum": [
      "1.0.0"
     ]
    },
    "proofSignature": {
     "type": "string",
     "pattern": "^[0-9a-f]{128}$"
    },
    "resolverDid": {
     "type": "string",
     "pattern": "^did:"
    }
   }
  },
  "ResolvedCredential": {
   "$id": "#/$defs/ResolvedCredential",
   "title": "ResolvedCredential",
   "description": "Final credential resolution result (used on the consumer side); removes the three fields freshnessVerified + chainVerified + popBindingValid; normalizedClaims uses oneOf + a source discriminator for type isolation",
   "type": "object",
   "required": [
    "crVersion",
    "link",
    "source",
    "normalizedClaims",
    "notRevoked",
    "integrityProof",
    "resolvedAt"
   ],
   "additionalProperties": false,
   "properties": {
    "crVersion": {
     "type": "string",
     "enum": [
      "1.0.0"
     ]
    },
    "link": {
     "$ref": "#/$defs/FederationIdentityLink"
    },
    "source": {
     "type": "string",
     "enum": [
      "oidc",
      "saml"
     ]
    },
    "normalizedClaims": {
     "oneOf": [
      {
       "$ref": "#/$defs/NormalizedOidcClaims"
      },
      {
       "$ref": "#/$defs/NormalizedSamlClaims"
      }
     ]
    },
    "notRevoked": {
     "type": "boolean",
     "const": true
    },
    "integrityProof": {
     "$ref": "#/$defs/ResolvedCredentialIntegrityProof"
    },
    "resolvedAt": {
     "type": "string",
     "format": "date-time"
    }
   }
  }
 }
}
