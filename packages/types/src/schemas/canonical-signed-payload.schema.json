{
 "$id": "https://coivitas.ai/schemas/canonical-signed-payload-v0.1.json",
 "title": "CanonicalSignedPayload",
 "description": "CSP v0.1 JSON Schema.",
 "type": "object",
 "required": [
  "cspVersion",
  "token",
  "disclosedClaims",
  "challenge",
  "audience",
  "notAfter"
 ],
 "additionalProperties": false,
 "properties": {
  "cspVersion": {
   "type": "string",
   "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
   "const": "1.0.0",
   "description": "CSP protocol version; the only valid value in v0.1 is '1.0.0'"
  },
  "token": {
   "type": "object",
   "required": [
    "id",
    "issuerDid",
    "principalDid",
    "issuedTo",
    "specVersion",
    "issuedAt",
    "expiresAt",
    "capabilities",
    "revocationUrl",
    "proof"
   ],
   "additionalProperties": false,
   "description": "The signed CapabilityToken (including proof). All fields are required and additionalProperties is false; scope.type uses the canonical wire encoding.",
   "properties": {
    "id": {
     "type": "string",
     "minLength": 1
    },
    "issuerDid": {
     "type": "string",
     "minLength": 1,
     "pattern": "^did:"
    },
    "principalDid": {
     "type": "string",
     "minLength": 1,
     "pattern": "^did:"
    },
    "issuedTo": {
     "type": "string",
     "minLength": 1,
     "pattern": "^did:"
    },
    "specVersion": {
     "type": "string",
     "enum": [
      "0.1.0",
      "0.2.0",
      "0.3.0"
     ]
    },
    "issuedAt": {
     "type": "string",
     "format": "date-time",
     "description": "ISO 8601 issuance timestamp (CapabilityToken authorization.ts Timestamp)"
    },
    "expiresAt": {
     "type": "string",
     "format": "date-time",
     "description": "ISO 8601 expiry timestamp (CapabilityToken authorization.ts Timestamp)"
    },
    "capabilities": {
     "type": "array",
     "minItems": 1,
     "description": "Capability list (authorization.ts Capability interface; every capability must carry an action and a scope)",
     "items": {
      "type": "object",
      "required": [
       "action",
       "scope"
      ],
      "properties": {
       "action": {
        "type": "string",
        "minLength": 1
       },
       "scope": {
        "type": "object",
        "required": [
         "type"
        ],
        "properties": {
         "type": {
          "type": "string",
          "description": "Scope discriminator (canonical wire values from authorization.ts)",
          "enum": [
           "allowlist",
           "numeric_limit",
           "temporal_scope",
           "cumulative_limit"
          ]
         }
        }
       }
      }
     }
    },
    "delegationChain": {
     "type": "array",
     "description": "Optional delegation chain (authorization.ts CapabilityToken.delegationChain optional)",
     "items": {
      "type": "object"
     }
    },
    "revocationUrl": {
     "type": "string",
     "format": "uri",
     "pattern": "^https://",
     "description": "Revocation check endpoint HTTPS URL (CapabilityToken authorization.ts — revocationUrl required, aligned with the TS interface)"
    },
    "proof": {
     "type": "object",
     "required": [
      "type",
      "created",
      "verificationMethod",
      "value"
     ],
     "description": "TokenProof with all fields aligned to the authorization.ts TS interface (type + created + verificationMethod + value, all 4 fields required)",
     "properties": {
      "type": {
       "type": "string",
       "minLength": 1,
       "enum": [
        "Ed25519Signature2026"
       ]
      },
      "created": {
       "type": "string",
       "format": "date-time",
       "description": "ISO 8601 proof creation timestamp (authorization.ts Timestamp)"
      },
      "verificationMethod": {
       "type": "string",
       "minLength": 1,
       "pattern": "^did:.*#",
       "description": "DID key reference (^did:.*# pattern; authorization.ts verificationMethod)"
      },
      "value": {
       "type": "string",
       "minLength": 1
      }
     },
     "additionalProperties": false
    }
   }
  },
  "disclosedClaims": {
   "type": "array",
   "description": "Set of claims disclosed under mode B selective disclosure; empty under mode A",
   "items": {
    "type": "object",
    "description": "ScopeClaim: selective disclosure representation of a Capability"
   }
  },
  "challenge": {
   "type": "string",
   "format": "uuid",
   "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
   "description": "Verifier-side issued nonce; UUID v4 format"
  },
  "audience": {
   "description": "Intended consumer of the token; a DID or an https URL",
   "oneOf": [
    {
     "type": "string",
     "format": "uri",
     "pattern": "^did:",
     "description": "DID-format audience"
    },
    {
     "type": "string",
     "format": "uri",
     "pattern": "^https://",
     "description": "HTTPS-URL-format audience"
    }
   ]
  },
  "notAfter": {
   "type": "string",
   "format": "date-time",
   "description": "Independent expiry window for the CSP signed payload; ISO 8601 UTC"
  }
 }
}
